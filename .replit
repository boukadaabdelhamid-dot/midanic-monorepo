modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/mobile-erp: expo"

[[workflows.workflow]]
name = "artifacts/mobile-erp: expo"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=19559 pnpm --filter @workspace/mobile-erp run dev"
waitForPort = 19559

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 8083
externalPort = 5000

[[ports]]
localPort = 18996
externalPort = 3002

[[ports]]
localPort = 19558
externalPort = 3001

[[ports]]
localPort = 19559
externalPort = 3003

[[ports]]
localPort = 19560
externalPort = 6000

[[ports]]
localPort = 23733
externalPort = 3000

[userenv]

[userenv.shared]
JWT_SECRET = "d952bc6cf967c4aba73081a26abb0a43017fe47f38c602f107b5ca43c6933bd8dbf926340bdef9efedf59b1404b4cb40"

