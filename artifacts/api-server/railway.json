{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --filter @workspace/api-server... --filter @workspace/db && pnpm --filter @workspace/api-server run build"
  },
  "deploy": {
    "startCommand": "cd /app/lib/db && pnpm exec drizzle-kit push --force --config ./drizzle.config.ts && node --enable-source-maps /app/artifacts/api-server/dist/index.mjs",
    "healthcheckPath": "/api/healthz",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
